# Root .env.example -- copy to .env locally (NEVER commit .env)
# Each app/package may have its own .env.example with overrides.

# --- Backend (used by /backend) ---
NODE_ENV=development
PORT=3001

# Postgres connection (Render injects DATABASE_URL automatically when linked)
DATABASE_URL=postgres://user:pass@localhost:5432/sports_outlet_ai

# Redis (for BullMQ; Render injects REDIS_URL automatically when linked)
REDIS_URL=redis://localhost:6379

# OpenAI (transcription + content generation + embeddings)
OPENAI_API_KEY=sk-...

# OpenRouter (used by legacy chatbot; optional if using OPENAI_API_KEY for chat too)
OPENROUTER_API_KEY=sk-or-v1-...
OPENROUTER_MODEL=openai/gpt-4o

# Pinecone (optional -- if not set, knowledge engine falls back to in-memory store)
PINECONE_API_KEY=
PINECONE_INDEX=sports-outlet-ai

# YouTube Data API (for ingestion-agent)
YOUTUBE_API_KEY=

# Magento (used by chatbot for live catalog lookups)
MAGENTO_BASE_URL=https://console.tennisoutlet.in/rest/V1
MAGENTO_STORE_URL=https://tennisoutlet.in
MAGENTO_TOKEN=
MAGENTO_CONSUMER_KEY=
MAGENTO_CONSUMER_SECRET=
MAGENTO_ACCESS_TOKEN=
MAGENTO_ACCESS_TOKEN_SECRET=

# Per-sport store URLs (used by chatbot for product links)
TENNIS_STORE_URL=https://tennisoutlet.in
PICKLEBALL_STORE_URL=https://pickleballoutlet.in
PADEL_STORE_URL=https://padeloutlet.in

# Cost guardrail (hard daily ceiling for LLM spend)
LLM_MAX_DAILY_USD=10

# Internal API key for protecting /ingest/* endpoints
INGEST_API_KEY=change-me-locally
